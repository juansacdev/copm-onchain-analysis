# RPC endpoints (one per chain you want to audit).
# Any provider works: a paid endpoint (faster, no rate limits) or a public
# one (free, but slower and rate-limited — the scanner backs off automatically).
POLYGON_RPC_URL=https://your-polygon-rpc-endpoint
CELO_RPC_URL=https://forno.celo.org

# COP per 1 USD used to convert volume figures (default: 4000).
# Set to your preferred constant or daily-snapshot rate.
COP_PER_USD=4000

# Parallel scan workers (default: 8). Lower this to 4-5 on public RPCs.
# SCAN_WORKERS=8
