# Polygon mainnet RPC (required).
# Recommended providers: Alchemy, Chainstack, QuickNode, Infura.
# A public RPC like https://polygon-rpc.com works but will be slow/rate-limited.
POLYGON_RPC_URL=https://polygon-mainnet.example.com/<your-api-key>

# COP per 1 USD used to convert volume figures (default: 4000).
# Set to your preferred constant or daily-snapshot rate.
COP_PER_USD=4000
