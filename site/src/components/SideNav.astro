---
interface Props {
  label: string;
  items: { href: string; num: string; text: string }[];
}

const { label, items } = Astro.props;
---

<nav id="sidenav" aria-label={label}>
  {items.map((item) => (
    <a href={item.href}><span class="num">{item.num}</span> {item.text}</a>
  ))}
</nav>

<script>
  // scrollspy de la navegación lateral + desplazamiento suave SOLO al
  // hacer click en un link (el scroll nativo no se toca)
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('#sidenav a'));
  const map = new Map<string, HTMLAnchorElement>();
  links.forEach((a) => map.set(a.getAttribute('href')!.slice(1), a));

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  links.forEach((a) => {
    a.addEventListener('click', (ev) => {
      const target = document.getElementById(a.getAttribute('href')!.slice(1));
      if (!target) return;
      ev.preventDefault();
      target.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth' });
      history.pushState(null, '', a.getAttribute('href'));
    });
  });

  const spy = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        const link = map.get(e.target.id);
        if (e.isIntersecting && link) {
          links.forEach((l) => l.classList.remove('active'));
          link.classList.add('active');
        }
      });
    },
    { rootMargin: '-20% 0px -70% 0px' }
  );
  map.forEach((_link, id) => {
    const sec = document.getElementById(id);
    if (sec) spy.observe(sec);
  });
</script>
